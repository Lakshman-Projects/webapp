{
    "agent": {
        "metrics_collection_interval": 60,
        "run_as_user": "root"
    },
    "metrics": {
        "namespace": "WebAppMetrics",
        "metrics_collected": {
            "statsd": {
                "service_address": ":8125"
            }
        }
    },
    "logs": {
        "logs_collected": {
            "files": {
                "collect_list": [
                    {
                        "file_path": "/opt/csye6225/webapp/logs/app.log",
                        "log_group_name": "WebAppLogs",
                        "log_stream_name": "{instance_id}"
                    }
                ]
            }
        }
    }
}